{
  "feature": "radii_cleaning",
  "enabled": true,
  "method": "default",
  "rules": {
    "small_radius_zero_only": true,
    "sanity_bounds": {
      "global": {
        "lower_percentile": 1.0,
        "upper_percentile": 99.5,
        "lower_abs": 0.05,
        "upper_abs": 30.0
      },
      "per_type": {
        "undefined": {
          "type_id": 0,
          "enabled": true,
          "lower_percentile": 1.0,
          "upper_percentile": 99.5,
          "lower_abs": 0.05,
          "upper_abs": 30.0
        },
        "soma": {
          "type_id": 1,
          "enabled": true,
          "lower_percentile": 1.0,
          "upper_percentile": 99.5,
          "lower_abs": 0.05,
          "upper_abs": 30.0
        },
        "axon": {
          "type_id": 2,
          "enabled": true,
          "lower_percentile": 1.0,
          "upper_percentile": 99.5,
          "lower_abs": 0.05,
          "upper_abs": 30.0
        },
        "basal dendrite": {
          "type_id": 3,
          "enabled": true,
          "lower_percentile": 1.0,
          "upper_percentile": 99.5,
          "lower_abs": 0.05,
          "upper_abs": 30.0
        },
        "apical dendrite": {
          "type_id": 4,
          "enabled": true,
          "lower_percentile": 1.0,
          "upper_percentile": 99.5,
          "lower_abs": 0.05,
          "upper_abs": 30.0
        }
      }
    },
    "local_outlier": {
      "enabled": true,
      "window_nodes": 5,
      "max_percent_deviation": 0.5
    },
    "taper": {
      "enabled": true,
      "slack": 0.05
    },
    "axon_floor": {
      "enabled": true,
      "min_radius": 0.12
    },
    "savgol": {
      "enabled": true,
      "window_nodes": 7,
      "polyorder": 2,
      "gaussian_sigma_fraction": 0.5
    },
    "fixed_point": {
      "enabled": true,
      "max_passes": 32,
      "min_effective_delta": 0.005
    },
    "replacement": {
      "clamp_min": 0.05,
      "clamp_max": 30.0
    }
  },
  "output": {
    "folder_suffix": "_radii_cleaned",
    "file_suffix": "_radii_cleaned",
    "report_name": "radii_cleaning_report.txt"
  }
}
