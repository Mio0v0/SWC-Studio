# Source distribution manifest.
#
# Setuptools by default includes every git-tracked file in the sdist.
# We exclude the model files from the sdist for the same reason
# pyproject.toml's package-data is empty: SWC-Studio uses Pattern B —
# code only ships via pip, models download from GitHub Releases on
# first use. See packaging/MODULAR_BUILD.md.
#
# Result: a fresh `pip install --no-binary :all: swcstudio` (source
# install) produces a model-less install; the first auto-label call
# triggers swcstudio.core.updater to download models on demand.

recursive-exclude swcstudio/data/models *
